{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "env": ["NODE_ENV", "PORT", "VITE_API_BASE_URL"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {},
    "type-check": {
      "dependsOn": ["^build"]
    },
    "lint": {}
  }
}
